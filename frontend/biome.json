{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules/",
      "!dist/",
      "!public/config.generated.yaml",
      "!public/index.html"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "root": "../"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "recommended": true,
        "noImportantStyles": "off"
      },
      "correctness": {
        "recommended": true,
        "noUnknownPseudoClass": "off"
      },
      "performance": {
        "recommended": true
      },
      "security": {
        "recommended": true
      },
      "style": {
        "recommended": true,
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "recommended": true,
        "noDocumentCookie": "off"
      },
      "a11y": {
        "useMediaCaption": "off",
        "useAltText": "off",
        "noRedundantAlt": "off",
        "noSvgWithoutTitle": "off",
        "useAriaPropsForRole": "off",
        "useGenericFontNames": "off",
        "noAutofocus": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true,
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "tab",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto"
  },
  "javascript": {
    "experimentalEmbeddedSnippetsEnabled": true,
    "formatter": {
      "enabled": true,
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "indentStyle": "tab",
      "indentWidth": 2,
      "lineWidth": 100,
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteProperties": "asNeeded",
      "operatorLinebreak": "after"
    },
    "linter": {
      "enabled": true
    },
    "assist": {
      "enabled": true
    },
    "globals": ["node"]
  },
  "json": {
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }, 
    "formatter": {
      "enabled": true,
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "cssModules": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    },
    "assist": {
      "enabled": true
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "parser": {
      "interpolation": true
    },
    "formatter": {
      "enabled": true,
      "indentScriptAndStyle": true
    },
    "linter": {
      "enabled": true
    },
    "assist": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["scripts/**/*.js", "tests/**/*.ts", "*.config.ts"],
      "javascript": {
        "globals": ["node"]
      }
    },
    {
      "includes": ["tests/playwright/**", "tests/mocks/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noEmptyPattern": "off"
          }
        }
      },
      "javascript": {
        "globals": ["node", "browser"]
      }
    }
  ]
}
